{
  "name": "graphite-mcp",
  "version": "1.0.0",
  "description": "MCP server for Graphite static analysis graphs",
  "type": "module",
  "bin": {
    "graphite-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
